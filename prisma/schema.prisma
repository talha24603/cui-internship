generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_qexKY2t7irSO@ep-young-breeze-ao0qmtfw-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

enum InternshipType {
  ONSITE
  REMOTE
  FIVERR
}

enum InternshipStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum InternshipApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InternshipAssignmentStatus {
  PENDING_VERIFICATION
  FACULTY_VERIFIED
  STUDENT_VERIFIED
  BOTH_VERIFIED
  CHANGES_REQUESTED
}

enum AdminApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  STUDENT
  FACULTY
  SITE_SUPERVISOR
  ADMIN
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ComplaintCategory {
  GENERAL
  INTERNSHIP_SITE
  FACULTY
  PLACEMENT_OFFICE
  OTHER
}

model User {
  id                      String           @id @default(uuid())
  email                   String           @unique
  password                String
  regNo                   String?
  name                    String?
  role                    Role
  verified                Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  companyId               String?

  tokens                  RefreshToken[]
  facultyProfile          FacultyProfile?

  internships             Internship[]     @relation("StudentInternships")
  facultyInternships      Internship[]     @relation("FacultyInternships")
  siteInternships         Internship[]     @relation("SiteInternships")

  evaluations             Evaluation[]

  companyRequests         CompanyRequest[]
  reviewedCompanyRequests CompanyRequest[] @relation("CompanyRequestReviewer")

  company                 Company?         @relation("CompanySiteSupervisors", fields: [companyId], references: [id])

  internshipApprovals     InternshipApproval[]
  internshipAssignments   InternshipAssignment[]
  internshipProposals     InternshipProposal[]

  facultySupervisorAssignments InternshipAssignment[] @relation("FacultySupervisorAssignments")
  siteSupervisorAssignments    InternshipAssignment[] @relation("SiteSupervisorAssignments")

  announcements          Announcement[]

  complaintsSubmitted    Complaint[] @relation("ComplaintSubmitted")
  complaintsHandled      Complaint[] @relation("ComplaintHandled")
}

/// One shared Word template for all students; admin replaces the file in place.
model UniversityReferenceLetter {
  id        String   @id
  fileUrl   String
  fileName  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model FacultyProfile {
  id     String @id @default(uuid())
  userId String @unique

  department     String?
  designation    String?
  phone          String?
  office         String?
  bio            String?
  avatarUrl      String?
  qualifications String?
  expertise      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("facultyProfile")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  website     String?
  industry    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  siteSupervisors User[] @relation("CompanySiteSupervisors")
}

model CompanyRequest {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String?
  address       String?
  website       String?
  industry      String?
  description   String?
  reason        String?
  status        String   @default("PENDING")

  requestedById String
  reviewedById  String?

  reviewedAt DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestedBy User  @relation(fields: [requestedById], references: [id])
  reviewedBy  User? @relation("CompanyRequestReviewer", fields: [reviewedById], references: [id])
}

model Internship {
  id        String @id @default(uuid())

  studentId String
  facultyId String?
  siteId    String?

  type      InternshipType
  startDate DateTime?
  endDate   DateTime?
  status    InternshipStatus

  /// Completion certificate from student (PDF/image); Cloudinary URL.
  certificateUrl         String?
  certificateFileName    String?
  certificateSubmittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student User  @relation("StudentInternships", fields: [studentId], references: [id])
  faculty User? @relation("FacultyInternships", fields: [facultyId], references: [id])
  site    User? @relation("SiteInternships", fields: [siteId], references: [id])

  reports     InternshipReport[]
  weeklyLogs  WeeklyLog[]
  evaluations Evaluation[]
  complaints  Complaint[]
  finalResult FinalResult?

  internshipApproval   InternshipApproval?

  // ✅ ADD THESE TWO
  internshipAssignment InternshipAssignment?
  internshipProposal   InternshipProposal?   @relation("InternshipProposalRecord")

  @@index([studentId])
  @@index([facultyId])
  @@index([siteId])
}
model Complaint {
  id              String            @id @default(uuid())
  subject         String
  body            String            @db.Text
  category        ComplaintCategory @default(GENERAL)
  status          ComplaintStatus   @default(OPEN)

  internshipId    String?
  submittedById   String
  handledById     String?

  resolutionNotes String? @db.Text
  handledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  internship  Internship? @relation(fields: [internshipId], references: [id])
  submittedBy User        @relation("ComplaintSubmitted", fields: [submittedById], references: [id])
  handledBy   User?       @relation("ComplaintHandled", fields: [handledById], references: [id])

  @@index([submittedById])
  @@index([internshipId])
  @@index([status, createdAt])
}
model InternshipApproval {
  id        String @id @default(uuid())

  studentId    String
  internshipId String @unique

  organization       String
  address            String
  industrySector     String
  contactName        String
  contactDesignation String
  contactPhone       String
  contactEmail       String
  internshipNature   String
  internshipLocation String
  mode               String
  numberOfInternship String

  startDate DateTime
  endDate   DateTime

  workingDays  String
  workingHours String
  status       InternshipApprovalStatus @default(PENDING)

  student    User        @relation(fields: [studentId], references: [id])
  internship Internship  @relation(fields: [internshipId], references: [id])

  @@index([studentId])
}
model InternshipAssignment {
  id String @id @default(uuid())

  internshipId String @unique
  studentId    String

  name           String
  degreeProgram  String
  email          String
  semester       String
  contactNo      String
  preferredField String

  companyName                String?
  internshipRole             String?
  facultySupervisorNameDesig String?
  siteSupervisorNameDesig    String?

  durationWeeks     Int?
  startDate         DateTime?
  endDate           DateTime?
  agreementAccepted Boolean

  status InternshipAssignmentStatus @default(PENDING_VERIFICATION)

  facultyId String?
  siteId    String?

  facultyVerified             Boolean?
  facultyVerifiedAt           DateTime?
  facultyVerificationComments String?

  studentVerified             Boolean?
  studentVerifiedAt           DateTime?
  studentVerificationComments String?

  adminApprovalStatus AdminApprovalStatus @default(PENDING)

  student User @relation(fields: [studentId], references: [id])

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  faculty User? @relation("FacultySupervisorAssignments", fields: [facultyId], references: [id])
  site    User? @relation("SiteSupervisorAssignments", fields: [siteId], references: [id])

  @@index([studentId])
  @@index([internshipId])
}

model InternshipProposal {
  id        String @id @default(uuid())

  studentId    String
  internshipId String? @unique

  organizationOverview String
  roleDescription      String
  keyActivities        String
  toolsTechnologies    String
  expectedDeliverables String

  submittedDate DateTime @default(now())

  student    User        @relation(fields: [studentId], references: [id])
  internship Internship? @relation("InternshipProposalRecord", fields: [internshipId], references: [id])

  @@index([studentId])
}

model InternshipReport {
  id           String   @id @default(uuid())
  internshipId String
  type         String
  fileUrl      String
  summary      String?
  submittedDate DateTime @default(now())

  internship Internship @relation(fields: [internshipId], references: [id])
}

model WeeklyLog {
  id             String   @id @default(uuid())
  internshipId   String
  weekNo         Int
  activitiesDone String
  skillsLearned  String
  challenges     String
  submittedDate  DateTime @default(now())

  internship Internship @relation(fields: [internshipId], references: [id])
}

model Evaluation {
  id           String   @id @default(uuid())
  internshipId String
  evaluatorId  String?

  type    String
  marks   Int
  comments String?
  details Json?

  submittedDate DateTime @default(now())

  internship Internship @relation(fields: [internshipId], references: [id])
  evaluator  User?      @relation(fields: [evaluatorId], references: [id])
}

model FinalResult {
  id           String @id @default(uuid())
  internshipId String @unique

  facultyMarks      Int
  siteMarks         Int?
  officeMarks       Int
  presentationMarks Int?
  totalMarks        Int

  status String

  isFinalizedByFaculty Boolean @default(false)
  finalizedAt          DateTime?
  finalizedById        String?
  hodSignatureUrl      String?

  internship Internship @relation(fields: [internshipId], references: [id])
}

model Announcement {
  id          String   @id @default(uuid())
  title       String?
  message     String
  link        String?
  pinned      Boolean  @default(false)

  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])

  @@index([pinned, createdAt])
}