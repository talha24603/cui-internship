{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "functions": {
    "src/app/api/cron/cleanup-tokens/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/cron/weekly-reminders/route.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-tokens",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly-reminders", 
      "schedule": "0 9 * * 1"
    }
  ]
}
